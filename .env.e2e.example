# E2E Test Configuration
# Copy this file to .env.e2e and fill in your test credentials

# Google Sheets Test Spreadsheet
SPREADSHEET_ID_E2E=your_spreadsheet_id_here

# OAuth Credentials
ACCOUNT_EMAIL_E2E=your-google-account@gmail.com
OAUTH_CLIENT_ID_E2E=your-oauth-client-id.apps.googleusercontent.com
OAUTH_CLIENT_SECRET_E2E=your-oauth-client-secret
OAUTH_REFRESH_TOKEN_E2E=your-oauth-refresh-token
