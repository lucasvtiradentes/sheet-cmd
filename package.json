{
  "name": "gsheet-lvt",
  "version": "0.1.0",
  "packageManager": "pnpm@10.11.0",
  "description": "A CLI tool to interact with Google Sheets - perfect for LLM integrations",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "gs": "./dist/cli.js",
    "gsheet": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "check": "biome check src/ scripts/ tests/",
    "check:fix": "biome check --fix src/ scripts/ tests/",
    "dev": "SHEET_CMD_PROG_NAME=gsheet tsx src/cli.ts",
    "dev:install": "tsx scripts/install-dev-version.ts",
    "dev:uninstall": "tsx scripts/uninstall-dev-version.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "postbuild": "pnpm gen:docs",
    "gen:docs": "tsx scripts/gen-docs.ts",
    "start": "SHEET_CMD_PROG_NAME=gsheet node dist/cli.js",
    "test:e2e": "vitest run --config tests/configs/e2e.vitest.config.ts",
    "format": "biome format --write .",
    "knip": "knip",
    "lint": "biome check --write .",
    "lint-staged": "lint-staged",
    "prepare": "husky",
    "changeset": "changeset",
    "release": "pnpm run build && changeset publish"
  },
  "keywords": [
    "google-sheets",
    "llm",
    "tool",
    "cli"
  ],
  "author": "Lucas Vieira",
  "license": "MIT",
  "homepage": "https://github.com/lucasvtiradentes/gsheet#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/lucasvtiradentes/gsheet.git"
  },
  "bugs": {
    "url": "https://github.com/lucasvtiradentes/gsheet/issues"
  },
  "dependencies": {
    "@caporal/core": "^2.0.7",
    "chalk": "^5.4.1",
    "google-auth-library": "^9.14.2",
    "google-spreadsheet": "^4.1.4",
    "googleapis": "^164.1.0",
    "inquirer": "^12.7.0",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.2",
    "@changesets/cli": "^2.29.7",
    "@types/node": "^22.18.8",
    "dotenv": "^17.2.3",
    "husky": "^9.1.7",
    "knip": "^6.4.1",
    "lint-staged": "^15.4.3",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}
